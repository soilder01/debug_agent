FROM node:20-bookworm AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONPATH=/app/backend/src \
    PATH=/opt/debug-agent-venv/bin:$PATH

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        python3 \
        python3-pip \
        python3-venv \
    && rm -rf /var/lib/apt/lists/* \
    && npm install -g @larksuite/cli \
    && python3 -m venv /opt/debug-agent-venv

COPY backend/pyproject.toml /app/backend/pyproject.toml
COPY backend/src /app/backend/src
COPY scripts /app/scripts

RUN python -m pip install --upgrade pip \
    && python -m pip install /app/backend

CMD ["python", "/app/scripts/lark_bot_long_connection_consumer.py", "--base-url", "http://backend:8000", "--transport", "sdk"]
