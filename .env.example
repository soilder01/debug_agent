# Copy to .env for local live-model development. Never commit real secrets.
# Replace this placeholder with your local Ark key before running live model calls.
ARK_API_KEY=replace-with-your-local-ark-api-key
ARK_BASE_URL=https://ark.example.com/api/v3
ARK_CONTENT_TASKS_URL=https://ark.example.com/api/v3/contents/generations/tasks
ARK_SEEDANCE2_MODEL_ID=replace-with-seedance2-model-id
ARK_SEED2_LITE_MODEL_ID=replace-with-seed2-lite-model-id
ARK_SEED2_PRO_MODEL_ID=replace-with-seed2-pro-model-id
ARK_CHAT_MODEL_ID=replace-with-chat-model-id
ARK_VIDEO_MODEL_ID=replace-with-video-model-id
ARK_VIDEO_MODE=high
ARK_VIDEO_DISABLE_THINKING=1
DEBUG_AGENT_DATABASE_URL=sqlite:///./debug_agent.db
DEBUG_AGENT_IMAGE_ARTIFACT_DIR=artifacts/image-crops
DEBUG_AGENT_ENVIRONMENT=local
DEBUG_AGENT_REPORT_BASE_URL=http://localhost:8000
DEBUG_AGENT_DOCKER_REPORT_BASE_URL=http://localhost:8080
DEBUG_AGENT_FRONTEND_PORT=8080
DEBUG_AGENT_AUTO_WRITEBACK_ENABLED=0
DEBUG_AGENT_AUTO_CLOSURE_ENABLED=1
DEBUG_AGENT_USAGE_BUDGET_UNITS=0
DEBUG_AGENT_ENFORCE_USAGE_BUDGET=0
DEBUG_AGENT_REQUIRE_TRUSTED_ACTOR=0
DEBUG_AGENT_ARTIFACT_RETENTION_DAYS=30
DEBUG_AGENT_QUEUE_MAX_CONCURRENCY=1
DEBUG_AGENT_RETRY_MAX_ATTEMPTS=2
DEBUG_AGENT_STALE_RUNNING_JOB_SECONDS=1800
DEBUG_AGENT_MODEL_PROVIDER=ark-video
DEBUG_AGENT_ENABLE_LIVE_MODEL_TESTS=0
LARK_SPREADSHEET_URL=
LARK_SHEET_ID=
LARK_CLI_TIMEOUT_SECONDS=60
LARK_CLI_PROFILE=xiaoD
LARK_CLI_IDENTITY=bot
LARK_APP_ID=
LARK_APP_SECRET=
LARK_REPORT_DOCS_ENABLED=0
LARK_REPORT_DOC_IDENTITY=user
LARK_REPORT_DOC_PROFILE=
LARK_REPORT_DOC_PARENT_TOKEN=
LARK_REPORT_DOC_PARENT_POSITION=
LARK_EVENT_MODE=long_connection
LARK_BOT_VERIFICATION_TOKEN=
LARK_BOT_ENCRYPT_KEY=
LARK_BOT_ACTION_TOKEN_SECRET=
